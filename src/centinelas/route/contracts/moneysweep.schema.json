{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Moneysweep-PR Intake Record",
  "description": "Financial and political intelligence signals",
  "type": "object",
  "required": ["schema_version", "item_id", "source_url", "title", "labels", "captured_at"],
  "properties": {
    "schema_version": { "type": "string" },
    "item_id": { "type": "string" },
    "source_url": { "type": "string", "format": "uri" },
    "source_name": { "type": "string" },
    "title": { "type": "string" },
    "body_text": { "type": "string" },
    "published_at": { "type": "string", "format": "date-time" },
    "captured_at": { "type": "string", "format": "date-time" },
    "evidence_tier": { "type": "string", "enum": ["T1", "T2", "T3", "T4"] },
    "labels": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "classifier_reasoning": { "type": "string" },
    "routed_to": { "type": "string" },
    "routed_at": { "type": "string", "format": "date-time" },
    "municipalities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Pre-officialization location enrichment; PR municipality names when the classifier could extract them (empty otherwise). MoneySweep re-derives from title/body_text when absent."
    },
    "agencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Agencies/entities implicated by the signal, when extracted."
    },
    "estimated_value": {
      "type": ["number", "null"],
      "description": "Estimated monetary value of the pre-official matter, USD, when known. Feeds the MoneySweep located-finance candidate amount."
    },
    "signal_stage": {
      "type": ["string", "null"],
      "description": "Pre-officialization lifecycle stage (e.g. announced, rfp_open, award_pending)."
    },
    "beat": {
      "type": ["string", "null"],
      "description": "Editorial beat (e.g. contracts, federal_funds, procurement)."
    }
  }
}
