{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skywatcher-PR Intake Record",
  "description": "Military, aerospace, and aviation intelligence signals",
  "type": "object",
  "required": ["schema_version", "item_id", "source_url", "title", "labels", "captured_at"],
  "properties": {
    "schema_version": { "type": "string" },
    "item_id": { "type": "string" },
    "source_url": { "type": "string", "format": "uri" },
    "source_name": { "type": "string" },
    "title": { "type": "string" },
    "body_text": { "type": "string" },
    "published_at": { "type": "string", "format": "date-time" },
    "captured_at": { "type": "string", "format": "date-time" },
    "evidence_tier": { "type": "string", "enum": ["T1", "T2", "T3", "T4"] },
    "labels": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "classifier_reasoning": { "type": "string" },
    "routed_to": { "type": "string" },
    "routed_at": { "type": "string", "format": "date-time" }
  }
}
