# Example environment configuration for centinelas-pr.
# Copy to `.env` and fill in real values. NEVER commit a real `.env`.
# No production credentials live in this repository.

# ── Classifier ───────────────────────────────────────────────────────────────
# Anthropic API key for the Claude Haiku classification tier
# (src/centinelas/classify/classifier.py; config/settings.yaml).
# Optional: without it the pipeline degrades gracefully to the keyword-rule tier.
ANTHROPIC_API_KEY=

# ── Federation dispatch (cross-repo egress to moneysweep-pr) ──────────────────
# GitHub token used by scripts/emit_dispatches.py for repository_dispatch.
# FEDERATION_DISPATCH_TOKEN is preferred; GITHUB_TOKEN is the fallback. Needs
# contents:write on the target repo. If neither is set, dispatch is skipped.
FEDERATION_DISPATCH_TOKEN=
GITHUB_TOKEN=

# ── Paths & routing (optional; all have defaults) ─────────────────────────────
# Local data directory (server/backend/main.py, route/dispatch.py). Default: .centinelas
CENTINELAS_DATA_DIR=
# Base dir for sibling producer checkouts (route/dispatch.py). Default: ~/Developer
CENTINELAS_REPOS_DIR=
# When set (CI / event-driven mode), routed payloads are staged here instead of a
# sibling checkout (scripts/emit_dispatches.py, route/dispatch.py). Default: unset
CENTINELAS_OUTBOUND_DIR=
# Minimum routing confidence threshold (route/dispatch.py). Default: 0.55
CENTINELAS_ROUTE_MIN_CONFIDENCE=
