{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Centinelas Item",
  "description": "A classified online intelligence item produced by centinelas-pr",
  "type": "object",
  "required": ["item_id", "source_url", "title", "labels", "captured_at"],
  "properties": {
    "item_id": {
      "type": "string",
      "description": "sha256(source_url + published_at)[:16] — idempotent dedup key"
    },
    "source_url": { "type": "string", "format": "uri" },
    "source_name": { "type": "string" },
    "title": { "type": "string" },
    "body_text": { "type": "string" },
    "published_at": { "type": "string", "format": "date-time" },
    "captured_at": { "type": "string", "format": "date-time" },
    "evidence_tier": {
      "type": "string",
      "enum": ["T1", "T2", "T3", "T4"],
      "description": "T1=primary/official source, T2=established media, T3=niche/unverified, T4=speculation"
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["ENVIRONMENTAL", "FINANCIAL", "POLITICAL", "GEO_GEOLOGY", "ANOMALOUS", "MILITARY_AEROSPACE", "SAFETY_COMPLIANCE", "UNCLASSIFIED"]
      },
      "minItems": 1
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "classifier_reasoning": { "type": "string" }
  }
}
